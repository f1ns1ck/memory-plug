{
  "description": "Automatically capture meaningful code changes into Change Memory after Claude edits files.",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/mcp-server/dist/cli/autoCapture.js\"",
            "timeout": 30,
            "statusMessage": "Updating Change Memory"
          }
        ]
      }
    ]
  }
}
