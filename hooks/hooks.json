{
  "description": "Automatically capture meaningful code changes into Change Memory after Claude edits files.",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "mcp_tool",
            "server": "change-memory",
            "tool": "auto_capture_change",
            "input": {
              "projectPath": "${CLAUDE_PROJECT_DIR}",
              "reason": "auto: ${tool_name} ${tool_input.file_path}",
              "sourceTool": "${tool_name}",
              "sourceFile": "${tool_input.file_path}",
              "debounceMs": 30000,
              "asHookOutput": true
            },
            "timeout": 30,
            "statusMessage": "Updating Change Memory"
          }
        ]
      }
    ]
  }
}
